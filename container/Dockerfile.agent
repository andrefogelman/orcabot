# OrcaBot Agent Container
# Spawned per-conversation with PDF pipeline, SINAPI lookup, and Excel export skills

FROM node:20-slim

# System deps: OCR, PDF rendering, Python for PaddleOCR
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    poppler-utils \
    tesseract-ocr \
    tesseract-ocr-por \
    fonts-liberation \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install PaddleOCR in a venv (avoids system package conflicts)
RUN python3 -m venv /opt/paddleocr && \
    /opt/paddleocr/bin/pip install --no-cache-dir paddlepaddle paddleocr

ENV PATH="/opt/paddleocr/bin:$PATH"

# Install Claude Code SDK globally
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

# Copy agent-runner (same as NanoClaw base)
COPY agent-runner/package*.json ./
RUN npm install
COPY agent-runner/ ./

# Copy skills
COPY skills/ ./skills/

# Build TypeScript
RUN npm run build

# Create workspace directories
RUN mkdir -p /workspace/group /workspace/global /workspace/extra \
    /workspace/ipc/messages /workspace/ipc/tasks /workspace/ipc/input

# Entrypoint: compile, read JSON from stdin, run agent
RUN printf '#!/bin/bash\nset -e\ncd /app && npx tsc --outDir /tmp/dist 2>&1 >&2\nln -s /app/node_modules /tmp/dist/node_modules\nchmod -R a-w /tmp/dist\ncat > /tmp/input.json\nnode /tmp/dist/index.js < /tmp/input.json\n' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

# Non-root user for security
RUN chown -R node:node /workspace && chmod 777 /home/node
USER node

WORKDIR /workspace/group

ENTRYPOINT ["/app/entrypoint.sh"]
