{
  "name": "orcabot",
  "version": "0.1.0",
  "description": "AI-powered construction budgeting on NanoClaw",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --env-file=.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.48.0",
    "@supabase/supabase-js": "^2.101.0",
    "@types/ws": "^8.18.1",
    "@xenova/transformers": "^2.17.2",
    "cron-parser": "5.5.0",
    "exceljs": "^4.4.0",
    "pdf-parse": "1.1.1",
    "pino": "^9.6.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
